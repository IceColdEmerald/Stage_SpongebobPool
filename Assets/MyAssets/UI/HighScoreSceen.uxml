                <ui:VisualElement picking-mode="Ignore" class="score-row" style="-unity-font-definition: url(&quot;project://database/Assets/MyAssets/Fonts/Malam%20Poek.ttf?fileID=12800000&amp;guid=6bf6f68195512d448bfb45024f4c5418&amp;type=3#Malam Poek&quot;);">
                    <ui:Label text="1." class="rank" style="-unity-font-style: normal;"/>
