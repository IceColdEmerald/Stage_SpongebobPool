    <ui:VisualElement name="screen" picking-mode="Ignore" style="background-image: url(&quot;project://database/Assets/MyAssets/Sprites/backgroundHighScores.png?fileID=2800000&amp;guid=0f3aa13baf916674db451773119ca825&amp;type=3#backgroundHighScores&quot;);">
        <ui:VisualElement name="scoreboard" picking-mode="Ignore" style="background-image: url(&quot;project://database/Assets/MyAssets/Sprites/HighScrores.png?fileID=2800000&amp;guid=82a9173629fd5014aa115ccbf996ec59&amp;type=3#HighScrores&quot;); -unity-font-definition: url(&quot;project://database/Assets/MyAssets/Fonts/Malam%20Poek.ttf?fileID=12800000&amp;guid=6bf6f68195512d448bfb45024f4c5418&amp;type=3#Malam Poek&quot;);">
            <ui:VisualElement name="header" picking-mode="Ignore" style="background-color: rgba(28, 58, 82, 0); position: relative; top: 5%;">
